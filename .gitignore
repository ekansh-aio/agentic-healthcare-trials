venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Database
*.db
*.sqlite
*.sqlite3

# Uploads & outputs (generated at runtime)
backend/uploads/
backend/outputs/

# Egg / dist
*.egg-info/
dist/
build/
.eggs/

