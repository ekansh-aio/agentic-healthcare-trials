# ─── Local development only ────────────────────────────────────────────────────
# Production secrets are in AWS Secrets Manager. This file is for local dev only.
# .env is in .gitignore — never commit this file.
 
# ─── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=
DEBUG=false
 
# ─── Database (local dev uses SQLite, production uses PostgreSQL via Secrets Manager) ──
DATABASE_URL=sqlite+aiosqlite:////db/marketing_platform.db
 
# ─── AWS Bedrock ───────────────────────────────────────────────────────────────
USE_BEDROCK=true
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL=us.anthropic.claude-sonnet-4-6
CHAT_MODEL=us.anthropic.claude-haiku-3-5-20241022
 
# ─── Anthropic Direct API (used when USE_BEDROCK=false) ────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
 
# ─── ElevenLabs ────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
 
# ─── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8001
 
# ─── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=/api

 
# ─── Open_AI ───────────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://ads-generation.cognitiveservices.azure.com/openai/deployments/gpt-image-1.5/images/generations?api-version=2024-02-01
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=
OPENAI_IMAGE_MODEL=